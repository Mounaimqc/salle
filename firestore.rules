rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // La configuration du hall (nom, devise, theme) peut être lue par n'importe qui au chargement de l'application
    match /settings/hall_settings {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Toutes les autres collections (reservations, clients, stock, charges, employes, utilisateurs) requièrent d'être authentifié
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
